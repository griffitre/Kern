; Simply counts down from 10 to 0, printing each step
; Ive tried to comment these examples as thoroughly as possible to make them easy to follow,
; even for someone unfamiliar with stack-based assembly/coding concepts as a whole (which is why theres literally a 1:1 line-to-comment ratio)
; If youre lost at any point, isa.md is a very good place to read more about how each thing works, so id suggest going there first

PUSH    10          ; push 10 onto the stack
STORE   0           ; store it to the first address

loop:               ; create a loop label
LOAD    0           ; load the value at the first address back onto the stack
LOAD    0           ; load the value at the first address again
PRINT               ; print the value loaded onto the stack
PUSH    1           ; push 1 onto the stack
SUB                 ; subtract 1 from the value loaded onto the stack
STORE   0           ; store the value to the first address
LOAD    0           ; load it back

JMP_IF_ZERO end     ; if the value is zero, jump to the end

JMP     loop        ; otherwise, loop again

end:                ; create an end label
LOAD    0           ; load the value at the first address
PRINT               ; print it (should be 0)
HALT                ; halt to end to the program